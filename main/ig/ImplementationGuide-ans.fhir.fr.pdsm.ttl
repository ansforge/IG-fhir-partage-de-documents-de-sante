       fhir:ImplementationGuide.definition.resource.name [ fhir:value "PDSm Comprehensive DocumentReference" ] ;
       fhir:ImplementationGuide.definition.resource.description [ fhir:value "Profil contenant les métadonnées du document ainsi que le lien vers la ressource Binary contenant le document dérivé de la ressource DocumentReference et du profil IHE MHD v4.0.1 \"ComprehensiveDocumentReference\"" ] ;
