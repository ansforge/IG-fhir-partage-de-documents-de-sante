@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<https://interop.esante.gouv.fr/ig/fhir/pdsm/Parameters/parameters-replace-cr-bio> a fhir:Parameters ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "parameters-replace-cr-bio"] ; # 
  fhir:parameter ( [
     fhir:name [ fhir:v "operation" ] ;
     fhir:part ( [
       fhir:name [ fhir:v "path" ] ;
       fhir:value [
         a fhir:String ;
         fhir:v "DocumentReference.status"
       ]
     ] [
       fhir:name [ fhir:v "type" ] ;
       fhir:value [
         a fhir:Code ;
         fhir:v "replace"
       ]
     ] [
       fhir:name [ fhir:v "value" ] ;
       fhir:value [
         a fhir:Code ;
         fhir:v "superseded"
       ]
     ] )
  ] ) . # 

