@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<https://interop.esante.gouv.fr/ig/fhir/pdsm/Patient/fr-patient-123> a fhir:Patient ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "fr-patient-123"] ;
  fhir:Resource.meta [
     fhir:Meta.profile [
       fhir:value "https://hl7.fr/ig/fhir/core/StructureDefinition/fr-core-patient" ;
       fhir:index -1 ;
       fhir:link <https://hl7.fr/ig/fhir/core/StructureDefinition/fr-core-patient>
     ]
  ] ;
  fhir:Resource.language [ fhir:value "en"] ;
  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: Patient fr-patient-123</b></p><a name=\"fr-patient-123\"> </a><a name=\"hcfr-patient-123\"> </a><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\"/><p style=\"margin-bottom: 0px\">Profile: <a href=\"https://hl7.fr/ig/fhir/core/2.1.0/StructureDefinition-fr-core-patient.html\">FR Core Patient Profile</a></p></div><p style=\"border: 1px #661aff solid; background-color: #e6e6ff; padding: 10px;\">Martin Claire  Male, DoB: 1980-01-15</p><hr/></div>"
  ] ;
  fhir:Patient.name [
     fhir:index -1 ;
     fhir:HumanName.family [ fhir:value "Claire" ] ;
     fhir:HumanName.given [
       fhir:value "Martin" ;
       fhir:index -1
     ]
  ] ;
  fhir:Patient.gender [ fhir:value "male"] ;
  fhir:Patient.birthDate [ fhir:value "1980-01-15"^^xsd:date] .

# - ontology header ------------------------------------------------------------

<https://interop.esante.gouv.fr/ig/fhir/pdsm/Patient/fr-patient-123.ttl> a owl:Ontology ;
  owl:imports fhir:fhir.ttl .

